# --- Primary LLM provider: 302.ai (OpenAI-compatible router) ---
LLM_PRIMARY_BASE_URL=https://api.302.ai/v1
LLM_PRIMARY_API_KEY=sk-302-...
LLM_PRIMARY_MODEL=gpt-4o-mini
LLM_PRIMARY_EMBED_MODEL=text-embedding-3-small

# --- Fallback LLM provider: MAI Qwen (OpenAI-compatible) ---
LLM_FALLBACK_BASE_URL=https://api.mai.example/v1
LLM_FALLBACK_API_KEY=sk-mai-...
LLM_FALLBACK_MODEL=qwen2.5-72b-instruct
LLM_FALLBACK_EMBED_MODEL=qwen-embedding

# --- App ---
PAIDEIA_DB_PATH=db/paideia.db
PAIDEIA_CONTENT_DIR=content
PAIDEIA_RAW_DIR=raw

# --- Auth ---
AUTH_SECRET=change-me-32-chars-min-please-change
AUTH_TOKEN_LIFETIME_SECONDS=3600

# --- Logging ---
LOG_LEVEL=INFO

# --- F12: ЮKassa (пожертвования) ---
# Получить: https://yookassa.ru/my → Настройки → API → Магазины
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Возврат после оплаты (опц., если не задано — берётся "https://<host>/support")
YOOKASSA_RETURN_URL=

# --- F12: СБП на телефон (для друзей-донатеров, без эквайринга) ---
# Номер в формате +7XXXXXXXXXX, банк по умолчанию (Сбер/Тинькофф/Альфа/Райф/...)
SBP_PHONE=
SBP_BANK_NAME=
SBP_HOLDER_NAME=
