# Заполнить и положить в /etc/paideia/paideia.env (chmod 600)

# 302.ai (primary LLM provider — OpenAI-compatible router)
LLM_PRIMARY_API_KEY=sk-...
LLM_PRIMARY_BASE_URL=https://api.302.ai/v1
LLM_PRIMARY_MODEL=gpt-4.1-mini
LLM_PRIMARY_DEEP_MODEL=gpt-5
LLM_PRIMARY_SEARCH_MODEL=sonar-pro
LLM_PRIMARY_EMBED_MODEL=text-embedding-3-small

# БД и контент
DB_PATH=/opt/paideia/app/db/paideia.db
PAIDEIA_CONTENT_DIR=/opt/paideia/app/content
PAIDEIA_ARCHIVE_DIR=/srv/paideia/archive
